{
    "name":  "alerthive-api",
    "version":  "1.0.0",
    "description":  "AlertHive REST API – Production backend for FedEx incident management platform",
    "type":  "commonjs",
    "scripts":  {
                    "dev":  "ts-node-dev --respawn --transpile-only src/index.ts",
                    "build":  "tsc -p tsconfig.json",
                    "start":  "node dist/index.js",
                    "db:migrate":  "prisma migrate deploy",
                    "db:seed":  "ts-node src/db/seed.ts",
                    "db:studio":  "prisma studio",
                    "lint":  "eslint src --ext .ts",
                    "perf:smoke":  "npx artillery run tests/load/smoke.yml",
                    "perf:load":  "node tests/load/perf-runner.mjs load",
                    "perf:spike":  "node tests/load/perf-runner.mjs spike",
                    "perf:bench":  "node tests/load/benchmark.js",
                    "perf:bench:quick":  "node tests/load/benchmark.js --duration=10",
                    "perf:cost":  "node tests/load/cost-estimate.js"
                },
    "dependencies":  {
                         "@prisma/client":  "^5.22.0",
                         "bcryptjs":  "^2.4.3",
                         "compression":  "^1.7.4",
                         "cors":  "^2.8.5",
                         "dotenv":  "^16.4.7",
                         "express":  "^4.21.2",
                         "express-rate-limit":  "^7.4.1",
                         "express-validator":  "^7.2.0",
                         "helmet":  "^8.0.0",
                         "ioredis":  "^5.10.0",
                         "jsonwebtoken":  "^9.0.2",
                         "kafkajs":  "^2.2.4",
                         "morgan":  "^1.10.0",
                         "uuid":  "^11.0.3",
                         "winston":  "^3.17.0",
                         "ws":  "^8.18.0",
                         "zod":  "^3.23.8"
                     },
    "devDependencies":  {
                            "@types/bcryptjs":  "^2.4.6",
                            "@types/compression":  "^1.7.5",
                            "@types/cors":  "^2.8.17",
                            "@types/express":  "^5.0.0",
                            "@types/jsonwebtoken":  "^9.0.7",
                            "@types/morgan":  "^1.9.9",
                            "@types/node":  "^22.10.2",
                            "@types/uuid":  "^10.0.0",
                            "@types/ws":  "^8.5.13",
                            "artillery":  "2.0.30",
                            "prisma":  "^5.22.0",
                            "ts-node-dev":  "^2.0.0",
                            "typescript":  "^5.7.2"
                        }
}
