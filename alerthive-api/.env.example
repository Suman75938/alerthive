# ============================================================
#  AlertHive API – Environment Variables
#  Copy this to .env and fill in real values before deploying
# ============================================================

# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_BASE_PATH=/api/v1

# ── Database (PostgreSQL) ─────────────────────────────────
# For development with Docker:  postgresql://alerthive:alerthive@localhost:5432/alerthive_db
# For production: use a managed service (AWS RDS, Azure DB, etc.)
DATABASE_URL="postgresql://alerthive:alerthive@localhost:5432/alerthive_db"

# ── JWT ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_USE_A_LONG_RANDOM_HEX_STRING_IN_PRODUCTION"
JWT_REFRESH_SECRET="CHANGE_ME_REFRESH_SECRET_DIFFERENT_FROM_ACCESS"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=info

# ── FedEx SSO (SAML/OIDC – add when integrating corporate IdP) ────────
# OIDC_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:4000/api/v1/auth/oidc/callback
