# Copy this to .env in the repo root before running: docker compose up
# These values override docker-compose.yml defaults.

# ── Secrets (CHANGE THESE before any real deployment) ────────────
JWT_SECRET=replace-with-min-32-char-random-string
JWT_REFRESH_SECRET=replace-with-another-min-32-char-string
ALERTHIVE_WEBHOOK_SECRET=alerthive-dt-secret-2026

# ── Token lifetimes ───────────────────────────────────────────────
JWT_ACCESS_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ── Allowed CORS origins (browser origin for the web container) ───
CORS_ORIGINS=http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Optional: Redis / Kafka (app runs without them in demo mode) ──
# REDIS_URL=redis://redis:6379
# KAFKA_BROKERS=kafka:9092
